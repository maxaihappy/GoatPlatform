# API
API_HOST=0.0.0.0
API_PORT=8000

# OpenAI (required for script generation; optional for DALL-E thumbnail)
OPENAI_API_KEY=sk-...

# ElevenLabs (optional; uses silent placeholder if not set)
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Video generation: set to false and provide RUNWAY_API_KEY for real clips
USE_PLACEHOLDER_CLIPS=true
RUNWAY_API_KEY=

# YouTube upload (optional)
YOUTUBE_UPLOAD_ENABLED=false
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Storage
STORAGE_PATH=./storage
OUTPUT_PATH=./output
